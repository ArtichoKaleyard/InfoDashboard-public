# Default to LF so Windows, WSL, Linux, and CI see the same text.
* text=auto eol=lf

# Source and project metadata.
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Kconfig* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.defaults text eol=lf
*.conf text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.ps1 text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pbm binary
*.bin binary
*.elf binary
*.a binary
*.o binary
